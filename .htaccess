# CMS push — cms-seo-sync.php reads this. Must match FRONTEND_SEO_SYNC_SECRET in Global CMS .env.
# Replace your-secret-here with your real random string on the server (avoid committing real secrets to git).
<IfModule mod_env.c>
  SetEnv CMS_SEO_SYNC_SECRET "Seosyncsecret123@"
</IfModule>

# SPA fallback with SEO prerender.
# Static files (JS, CSS, images, fonts) are served directly by Apache.
# All other requests go through seo-prerender.php which injects correct
# per-page meta tags into index.html before serving.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files first — after CMS "push", robots.txt / sitemap.xml on disk win over the live-fetch PHP fallback
  # Exception: site root "/" must NOT short-circuit to index.html here — we need seo-prerender.php to inject locale meta in view-source.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteCond %{REQUEST_URI} !^/?$
  RewriteRule . - [L]

  # No file yet: pull live from CMS (optional)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^robots\.txt$ /robots-cms.php [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^sitemap\.xml$ /sitemap-cms.php [L]

  # Serve real directories directly (but not document root — otherwise "/" stops here and never hits seo-prerender.php)
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !^/?$
  RewriteRule . - [L]

  # Everything else → PHP prerender (injects CMS meta into index.html)
  RewriteRule . /seo-prerender.php [L]
</IfModule>

# Prevent directory listing
Options -Indexes

# Block access to the cache directory
<IfModule mod_rewrite.c>
  RewriteRule ^_seo_cache/ - [F,L]
</IfModule>

# Cache static assets aggressively
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>
